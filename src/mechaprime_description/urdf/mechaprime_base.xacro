            <geometry>
                <sphere radius="0.00625"/>
                <!-- mesh filename="package://mechaprime_description/meshes/front_right_castor.stl" scale="0.001 0.001 0.001"/-->
            </geometry>
            <material name="grey">
                <color rgba="0.8 0.8 0.8 1.0"/>
            </material>
        </collision>
    </link>

    <joint name="front_right_castor_joint" type="fixed">
